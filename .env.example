# Edamam Recipe Search API v2 credentials.
# Get them from https://developer.edamam.com/ (Recipe Search API).
# Copy this file to `.env` and fill in your keys. Vite exposes VITE_* vars to the client.
VITE_EDAMAM_APP_ID=your_app_id_here
VITE_EDAMAM_APP_KEY=your_app_key_here

# Optional: only for Edamam plans that support active-user tracking.
# Leave unset (or USE_ACCOUNT_USER=false) for standard Recipe Search API apps.
# VITE_EDAMAM_USE_ACCOUNT_USER=true
# VITE_EDAMAM_ACCOUNT_USER=your_account_user_id

# Firebase web app config (Project settings > General > Your apps > SDK setup).
# Enables Google sign-in, saved allergen settings, and saved recipes.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
